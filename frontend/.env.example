# REST API base URL (used for login, fleet, missions, config).
# Change for production or when backend runs on another host/port.
VITE_API_URL=http://localhost:8000

# Optional: WebSocket URL for fleet telemetry stream.
# If unset, derived from VITE_API_URL as {origin}/ws/fleet
# VITE_WS_URL=ws://localhost:8000/ws/fleet

# Optional: Mapbox access token for Mapbox satellite basemap. If unset, Esri satellite is used (no key).
# VITE_MAPBOX_TOKEN=pk.eyJ...
