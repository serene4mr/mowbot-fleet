{
    "name": "mowbot-fleet-dev",
    "runArgs": [
        "--publish", "5174:5174",
        "--publish", "8000:8000"
    ],
    "build": {
        "dockerfile": "Dockerfile",
        "context": "..",
        "args": {
            "USERNAME": "${localEnv:USER}",
            "BASE_IMAGE": "mcr.microsoft.com/devcontainers/python:3.11-bookworm"
        }
    },
    // Map the container user to your local host user to avoid file permission issues
    "remoteUser": "${localEnv:USER}",
    "updateRemoteUserUID": true,
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-vscode.vscode-typescript-next",
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "ms-azuretools.vscode-docker",
                "tamasfe.even-better-toml"
            ]
        }
    },
    "mounts": [
        // Persist bash history across container rebuilds
        "source=mowbot-bashhistory,target=/home/${localEnv:USER}/.bash_history,type=volume",
        // Bind Docker socket to allow Docker-in-Docker functionality
        "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
    ],
    // Forward ports for the TS Web Dashboard (3000), FastAPI Master Controller (8000),
    // and the Vite frontend dev server (5174).
    "forwardPorts": [3000, 8000, 5174]
}